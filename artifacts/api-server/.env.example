# EventFlow - API Server Environment Variables

# === DATABASE ===
# PostgreSQL Connection String
# Local: postgresql://username:password@localhost:5432/eventflow
# Cloud (Neon): postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/eventflow
DATABASE_URL=postgresql://postgres:password@localhost:5432/eventflow

# === SESSION ===
# Secret key for encrypting session cookies
# IMPORTANT: Change this to a random string in production!
# Example: openssl rand -base64 32
SESSION_SECRET=your_super_secret_session_key_change_this_12345

# === SERVER ===
# Port the API server listens on
PORT=3001

# === ENVIRONMENT ===
# Set to 'development' for local testing
# Set to 'production' for production deployment
NODE_ENV=development

# === BASE PATH (Optional) ===
# If running behind a proxy with a path prefix
# Example: /api for https://example.com/api
BASE_PATH=
