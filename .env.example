# Copy this file to .env and fill in the values

# Database (required) - get this from your Neon dashboard
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# API Server
SESSION_SECRET=change-this-to-a-random-secret-in-production

# Frontend base path
BASE_PATH=/

# App URL — used for QR code generation.
# When running locally and scanning QR codes from a phone,
# set this to your computer's local network IP shown in the Vite output.
# Example: if Vite shows "Network: http://10.167.136.188:5173", use that.
# Leave empty in production (it auto-detects from the request).
APP_URL=http://YOUR_LOCAL_IP:5173
